# ─── Database ──────────────────────────────────────────────────────
APP_CONFIG__DB__URL=postgresql+asyncpg://user:password@localhost:5432/dating
APP_CONFIG__DB__ECHO=false
APP_CONFIG__DB__POOL_SIZE=50
APP_CONFIG__DB__MAX_OVERFLOW=10

# ─── Auth ──────────────────────────────────────────────────────────
APP_CONFIG__SECRET_KEY=change-me-in-production
APP_CONFIG__ACCESS_TOKEN__LIFETIME_SECONDS=3600
APP_CONFIG__ACCESS_TOKEN__RESET_PASSWORD_TOKEN_SECRET=change-me
APP_CONFIG__ACCESS_TOKEN__VERIFICATION_TOKEN_SECRET=change-me

# ─── Server ────────────────────────────────────────────────────────
APP_CONFIG__RUN__HOST=0.0.0.0
APP_CONFIG__RUN__PORT=8000
APP_CONFIG__GUNICORN__HOST=0.0.0.0
APP_CONFIG__GUNICORN__PORT=8000
APP_CONFIG__GUNICORN__WORKERS=2
APP_CONFIG__GUNICORN__TIMEOUT=90

# ─── Logging ───────────────────────────────────────────────────────
APP_CONFIG__LOGGING__LOG_LEVEL=info

# ─── Redis ─────────────────────────────────────────────────────────
APP_CONFIG__REDIS_URL=redis://localhost:6379

# ─── CORS ──────────────────────────────────────────────────────────
APP_CONFIG__CORS__ALLOWED_ORIGINS=["https://your-domain.com"]

# ─── API ───────────────────────────────────────────────────────────
APP_CONFIG__API__PREFIX=/api

# ─── Telegram Bot ──────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://your-domain.com
REDIS_URL=redis://localhost:6379

# ─── PostgreSQL (Docker) ──────────────────────────────────────────
POSTGRES_DB=dating
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-in-production
